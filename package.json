{
  "name": "gitable",
  "displayName": "Gitable",
  "description": "AI-powered Git workflow panel for VS Code. Generate commit messages, review changes, and manage Git visually using your own AI API key.",
  "version": "1.3.9",
  "icon": "media/icon.png",
  "publisher": "piyushdoorwar",
  "license": "MIT",
  "author": {
    "name": "Piyush Doorwar"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/piyushdoorwar/gitable.git"
  },
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=24"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "ai",
    "commit",
    "openai",
    "gemini",
    "claude"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Gitable",
      "properties": {
        "gitable.autoFetch.intervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "markdownDescription": "How often Gitable fetches from origin in the background (while the panel is visible) to keep the ahead/behind counts current, in minutes. Set to `0` to disable background fetching."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitable",
          "title": "Gitable",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "gitable": [
        {
          "id": "gitable.panel",
          "name": "Gitable",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "gitable.refresh",
        "title": "Gitable: Refresh",
        "category": "Gitable",
        "icon": "$(refresh)"
      },
      {
        "command": "gitable.generateCommitMessage",
        "title": "Gitable: Generate AI Commit Message",
        "category": "Gitable",
        "icon": "$(sparkle)"
      },
      {
        "command": "gitable.commit",
        "title": "Gitable: Commit",
        "category": "Gitable",
        "icon": "$(check)"
      },
      {
        "command": "gitable.stageAll",
        "title": "Gitable: Stage All Changes",
        "category": "Gitable"
      },
      {
        "command": "gitable.unstageAll",
        "title": "Gitable: Unstage All Changes",
        "category": "Gitable"
      },
      {
        "command": "gitable.openSettings",
        "title": "Gitable: Open Settings",
        "category": "Gitable",
        "icon": "$(gear)"
      },
      {
        "command": "gitable.validateApiKey",
        "title": "Gitable: Validate API Key",
        "category": "Gitable"
      },
      {
        "command": "gitable.push",
        "title": "Gitable: Push",
        "category": "Gitable"
      },
      {
        "command": "gitable.pull",
        "title": "Gitable: Pull",
        "category": "Gitable"
      },
      {
        "command": "gitable.createBranch",
        "title": "Gitable: Create Branch",
        "category": "Gitable"
      },
      {
        "command": "gitable.switchBranch",
        "title": "Gitable: Switch Branch",
        "category": "Gitable"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitable.refresh",
          "when": "view == gitable.panel",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no linter configured)\" && exit 0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.2.0",
    "chart.js": "^4.5.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
